# =============================================================================
# .env.example — Variables de entorno para el pipeline Hidrandina
# Copiar a .env y ajustar según entorno:
#   cp .env.example .env
# =============================================================================

# Modo de ejecución: "simulado" (sin Kafka) o "real" (con Kafka)
MODO=simulado

# Kafka (solo si MODO=real)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=hidrandina-consumo

# Spark
SPARK_MASTER=local[*]

# Rutas dentro del contenedor
RUTA_PROYECTO=/app
RUTA_DATA=/app/data
RUTA_SERVING=/app/output

# Python
PYTHONUNBUFFERED=1
